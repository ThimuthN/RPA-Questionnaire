generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppAccessLevel {
  admin
  recruiter
  hiring_manager
  interviewer
  member
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  title         String?
  department    String?
  phone         String?
  accessLevel   AppAccessLevel     @default(member)
  passwordHash  String?
  isInterviewer Boolean            @default(false)
  isActive      Boolean            @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AssessmentTemplate {
  id          String   @id @default(cuid())
  title       String
  status      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssessmentVersion {
  id               String   @id @default(cuid())
  templateId       String
  versionNumber    Int
  blueprintJson    Json
  questionBankRef  String
  practicalPackRef String
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model AddonCatalog {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  label                 String
  description           String
  assessmentTypeId      String   @map("engineType")
  defaultConfigJson     Json
  defaultDurationMinutes Int
  defaultRequiredPercent Int
  defaultWeight         Int
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  presetItems           AssessmentPresetItem[]

  @@index([isActive, sortOrder])
}

model AssessmentPreset {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       AssessmentPresetItem[]
  jobPostings JobPosting[]

  @@index([isActive, sortOrder])
}

model AssessmentPresetItem {
  id                 String   @id @default(cuid())
  presetId           String
  addonId            String
  sortOrder          Int
  configOverrideJson Json?
  weightOverride     Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  preset             AssessmentPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  addon              AddonCatalog     @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@index([presetId, sortOrder])
  @@index([addonId])
}

model Invite {
  id                  String   @id @default(cuid())
  assessmentVersionId String
  mode                String
  contextType         String   @default("general")
  slug                String   @unique
  tokenHash           String   @unique
  passcodeHash        String?
  integrityPreset     String?
  roleLocked          Boolean  @default(true)
  stackLocked         Boolean  @default(true)
  roleId              String?
  passTargetPercent   Int?
  stacksJson          Json?
  sectionsJson        Json?
  blueprintJson       Json?
  maxAttempts         Int      @default(1)
  usedAttempts        Int      @default(0)
  expiresAt           DateTime?
  createdAt           DateTime @default(now())
  attempts            Attempt[]
  candidateAssessments CandidateAssessment[]

  @@index([assessmentVersionId])
}

model RoleCatalog {
  id              String   @id @default(cuid())
  slug            String   @unique
  label           String
  department      String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  candidates      Candidate[]
  jobPostings     JobPosting[]

  @@index([isActive, sortOrder])
  @@index([label, department])
}

model Participant {
  id         String   @id @default(cuid())
  kind       String
  fullName   String
  email      String
  phone      String?
  employeeId String?
  createdAt  DateTime @default(now())
  attempts   Attempt[]

  @@unique([kind, email])
}

model Attempt {
  id                     String   @id @default(cuid())
  assessmentVersionId    String
  inviteId               String?
  participantId          String
  contextType            String   @default("general")
  integrityPreset        String?
  roleId                 String?
  passTargetPercent      Int
  stacksJson             Json
  sectionsJson           Json
  blueprintJson          Json?
  sectionStateJson       Json?
  seed                   Int
  stage                  String
  status                 String
  coreQuestionIdsJson    Json
  coreAnswersJson        Json
  practicalAnswerJson    Json
  practicalEarned        Float    @default(0)
  practicalPossible      Float    @default(0)
  logicReasoningAnswerJson Json?
  logicReasoningEarned   Float    @default(0)
  logicReasoningPossible Float    @default(0)
  remainingCoreSeconds   Int
  remainingPracticalSeconds Int
  remainingLogicReasoningSeconds Int?
  stateVersion           Int      @default(0)
  integrityJson          Json
  startedAt              DateTime @default(now())
  submittedAt            DateTime?
  invite                 Invite?  @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  participant            Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  result                 Result?
  candidateAssessment    CandidateAssessment?
  candidateAssessmentAttempts CandidateAssessmentAttempt[]

  @@index([inviteId])
  @@index([participantId])
  @@index([status, startedAt])
}

model Result {
  id               String   @id @default(cuid())
  attemptId        String   @unique
  contextType      String   @default("general")
  reviewState      String   @default("unreviewed")
  corePercent      Float
  practicalPercent Float
  finalPercent     Float
  pass             Boolean
  borderline       Boolean
  breakdownJson    Json
  exportedAt       DateTime?
  createdAt        DateTime @default(now())
  attempt          Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([finalPercent])
  @@index([reviewState, createdAt])
}

model MagicToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Candidate {
  id                 String   @id @default(cuid())
  fullName           String
  email              String   @unique
  phone              String?
  roleId             String?
  positionAppliedFor String?
  batchId            String?
  resumeSource       String?
  hrOwner            String?
  intakeBucket       String   @default("pipeline")
  stage              String   @default("new")
  finalDecision      String   @default("in_process")
  nextAction         String   @default("none")
  screeningStatus    String?
  candidateFolderUrl String?
  notesSummary       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  role               RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  resumes            CandidateResume[]
  assessments        CandidateAssessment[]
  notes              CandidateNote[]
  milestones         CandidateMilestone[]
  applications       CandidateApplication[]
  activityEvents     CandidateActivityEvent[]
  @@index([roleId])
  @@index([stage, updatedAt])
  @@index([intakeBucket, updatedAt])
}

model CandidateResume {
  id         String   @id @default(cuid())
  candidateId String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  storageUrl String
  uploadedAt DateTime @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, storageKey])
  @@index([candidateId, uploadedAt])
}

model CandidateAssessment {
  id          String   @id @default(cuid())
  candidateId String
  inviteId    String   @unique
  attemptId   String?  @unique
  createdAt   DateTime @default(now())
  createdById String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  invite      Invite    @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  attempt     Attempt?  @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  attemptHistory CandidateAssessmentAttempt[]
  milestones  CandidateMilestone[]

  @@index([candidateId, createdAt])
}

model CandidateAssessmentAttempt {
  id                  String   @id @default(cuid())
  candidateAssessmentId String
  attemptId           String   @unique
  linkedAt            DateTime @default(now())
  candidateAssessment CandidateAssessment @relation(fields: [candidateAssessmentId], references: [id], onDelete: Cascade)
  attempt             Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([candidateAssessmentId, attemptId])
  @@index([candidateAssessmentId, linkedAt])
}

model CandidateNote {
  id          String   @id @default(cuid())
  candidateId String
  type        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
}

model CandidateMilestone {
  id                   String   @id @default(cuid())
  candidateId          String
  type                 String
  title                String
  status               String
  sortOrder            Int
  mode                 String
  date                 DateTime?
  notes                String?
  score                Float?
  result               String?
  recommendation       String?
  candidateAssessmentId String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateAssessment  CandidateAssessment? @relation(fields: [candidateAssessmentId], references: [id], onDelete: SetNull)
  checks               CandidateMilestoneCheck[]

  @@index([candidateId, sortOrder])
}

model CandidateMilestoneCheck {
  id          String   @id @default(cuid())
  milestoneId String
  type        String
  status      String
  notes       String?
  actorId     String?
  actorName   String?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  milestone   CandidateMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, type])
  @@index([milestoneId])
}

model CandidateActivityEvent {
  id         String   @id @default(cuid())
  candidateId String
  actorId    String?
  actorName  String?
  event      String
  entityType String?
  entityId   String?
  detail     String?
  createdAt  DateTime @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
}

model JobPosting {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  roleId      String?
  screenerPresetId String?
  summary     String
  description String
  isPublished Boolean  @default(false)
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  role        RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  screenerPreset AssessmentPreset? @relation(fields: [screenerPresetId], references: [id], onDelete: SetNull)
  applications CandidateApplication[]

  @@index([roleId])
  @@index([screenerPresetId])
  @@index([isPublished, isOpen, updatedAt])
}

model CandidateApplication {
  id           String   @id @default(cuid())
  candidateId  String
  jobPostingId String
  status       String
  coverNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobPostingId])
  @@index([candidateId, createdAt])
  @@index([jobPostingId, status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actorEmail String?
  targetId   String
  targetType String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([targetId, targetType])
  @@index([actorId])
  @@index([createdAt])
}
