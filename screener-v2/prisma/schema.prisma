generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AttemptStatus {
  in_progress
  submitted
  graded
  reviewed
}

enum ResultReviewState {
  unreviewed
  reviewed
  flagged
}

enum CandidateMilestoneStatus {
  not_started
  in_progress
  done
  failed
  skipped
}

enum CandidateOfferStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Department {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  roles     RoleCatalog[]
  users     User[]
  candidates Candidate[]
  employees Employee[]
  jobPostings JobPosting[]
  departmentCandidacies DepartmentCandidacy[]

  @@index([isActive, sortOrder])
}

model User {
  id                      String                @id @default(cuid())
  email                   String                @unique
  name                    String?
  departmentId            String?
  roleId                  String?
  passwordHash            String?
  isActive                Boolean               @default(true)
  lastLoginAt             DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  dept                    Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role                    RoleCatalog?          @relation(fields: [roleId], references: [id], onDelete: SetNull)
  ownedCandidates         Candidate[]           @relation("HROwner")
  interviewPanels         InterviewPanelMember[]
  interviewFeedbacks      InterviewFeedback[]
  permissionOverrides     UserPermissionOverride[]

  @@index([departmentId])
  @@index([roleId])
}

model AssessmentTemplate {
  id          String   @id @default(cuid())
  title       String
  status      String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AssessmentVersion {
  id               String   @id @default(cuid())
  templateId       String
  versionNumber    Int
  blueprintJson    Json
  questionBankRef  String
  practicalPackRef String
  isPublished      Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model AddonCatalog {
  id                    String   @id @default(cuid())
  slug                  String   @unique
  label                 String
  description           String
  assessmentTypeId      String   @map("engineType")
  defaultConfigJson     Json
  defaultDurationMinutes Int
  defaultRequiredPercent Int
  defaultWeight         Int
  isActive              Boolean  @default(true)
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  presetItems           AssessmentPresetItem[]

  @@index([isActive, sortOrder])
}

model AssessmentPreset {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  description String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       AssessmentPresetItem[]
  jobPostings JobPosting[]

  @@index([isActive, sortOrder])
}

model AssessmentPresetItem {
  id                 String   @id @default(cuid())
  presetId           String
  addonId            String
  sortOrder          Int
  configOverrideJson Json?
  weightOverride     Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  preset             AssessmentPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  addon              AddonCatalog     @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@index([presetId, sortOrder])
  @@index([addonId])
}

model Invite {
  id                  String   @id @default(cuid())
  assessmentVersionId String
  mode                String
  contextType         String   @default("general")
  slug                String   @unique
  tokenHash           String   @unique
  passcodeHash        String?
  integrityPreset     String?
  roleLocked          Boolean  @default(true)
  stackLocked         Boolean  @default(true)
  roleId              String?
  passTargetPercent   Int?
  stacksJson          Json?
  sectionsJson        Json?
  blueprintJson       Json?
  maxAttempts         Int      @default(1)
  usedAttempts        Int      @default(0)
  expiresAt           DateTime?
  createdAt           DateTime @default(now())
  attempts            Attempt[]
  candidateAssessments CandidateAssessment[]

  @@index([assessmentVersionId])
}

model RoleCatalog {
  id                      String                      @id @default(cuid())
  slug                    String                      @unique
  label                   String
  department              String?
  departmentId            String
  sortOrder               Int                         @default(0)
  isActive                Boolean                     @default(true)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  dept                    Department                  @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  candidates              Candidate[]
  employees               Employee[]
  jobPostings             JobPosting[]
  departmentCandidacies   DepartmentCandidacy[]
  users                   User[]
  permissions             RolePermissionTemplate[]

  @@index([isActive, sortOrder])
  @@index([label, department])
  @@index([departmentId])
}

model RolePermissionTemplate {
  id        String   @id @default(cuid())
  roleId    String
  role      RoleCatalog @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String
  scope     String   @default("own_dept")
  createdAt DateTime @default(now())

  @@unique([roleId, permission])
  @@index([roleId])
}

model UserPermissionOverride {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  action    String
  grantedBy String
  reason    String?
  grantedAt DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model Participant {
  id         String   @id @default(cuid())
  kind       String
  fullName   String
  email      String
  phone      String?
  employeeId String?
  createdAt  DateTime @default(now())
  attempts   Attempt[]

  @@unique([kind, email])
}

model Attempt {
  id                     String         @id @default(cuid())
  assessmentVersionId    String
  inviteId               String?
  participantId          String
  contextType            String         @default("general")
  integrityPreset        String?
  roleId                 String?
  passTargetPercent      Int
  stacksJson             Json
  sectionsJson           Json
  blueprintJson          Json?
  sectionStateJson       Json?
  seed                   Int
  stage                  String
  status                 AttemptStatus
  coreQuestionIdsJson    Json
  coreAnswersJson        Json
  practicalAnswerJson    Json
  practicalEarned        Float          @default(0)
  practicalPossible      Float          @default(0)
  logicReasoningAnswerJson Json?
  logicReasoningEarned   Float          @default(0)
  logicReasoningPossible Float          @default(0)
  remainingCoreSeconds   Int
  remainingPracticalSeconds Int
  remainingLogicReasoningSeconds Int?
  stateVersion           Int            @default(0)
  integrityJson          Json
  startedAt              DateTime       @default(now())
  submittedAt            DateTime?
  invite                 Invite?        @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  participant            Participant    @relation(fields: [participantId], references: [id], onDelete: Restrict)
  result                 Result?
  candidateAssessment    CandidateAssessment?
  candidateAssessmentAttempts CandidateAssessmentAttempt[]

  @@index([inviteId])
  @@index([participantId])
  @@index([status, startedAt])
}

model Result {
  id               String              @id @default(cuid())
  attemptId        String              @unique
  contextType      String              @default("general")
  reviewState      ResultReviewState   @default(unreviewed)
  corePercent      Float
  practicalPercent Float
  finalPercent     Float
  pass             Boolean
  borderline       Boolean
  breakdownJson    Json
  exportedAt       DateTime?
  createdAt        DateTime            @default(now())
  attempt          Attempt             @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([finalPercent])
  @@index([reviewState, createdAt])
  @@index([contextType, reviewState, createdAt])
}

model MagicToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model Candidate {
  id                 String   @id @default(cuid())
  fullName           String
  email              String   @unique
  phone              String?
  roleId             String?
  departmentId       String?
  hrOwnerId          String?
  positionAppliedFor String?
  batchId            String?
  resumeSource       String?
  hrOwner            String?
  stage              String   @default("pipeline")
  nextAction         String   @default("none")
  screeningStatus    String?
  candidateFolderUrl String?
  notesSummary       String?
  orgStatus          String   @default("active")
  searchVector       Unsupported("tsvector")?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  role               RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department         Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  hrOwnerUser        User? @relation("HROwner", fields: [hrOwnerId], references: [id], onDelete: SetNull)
  resumes            CandidateResume[]
  assessments        CandidateAssessment[]
  notes              CandidateNote[]
  milestones         CandidateMilestone[]
  applications       CandidateApplication[]
  activityEvents     CandidateActivityEvent[]
  interviewPanels    InterviewPanel[]
  offer              CandidateOffer?
  employee           Employee?
  departmentCandidacies DepartmentCandidacy[]
  @@index([roleId])
  @@index([departmentId])
  @@index([hrOwnerId])
  @@index([stage, updatedAt])
  @@index([fullName])
  @@index(fields: [searchVector], type: Gin, map: "candidate_fts_idx")
}

model DepartmentCandidacy {
  id             String   @id @default(cuid())
  candidateId    String
  departmentId   String
  roleId         String?
  hrOwnerId      String?
  status         String   @default("active")
  source         String   @default("manual")
  nominatedBy    String?
  nominationNote String?
  jobPostingId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidate  Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  department Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role       RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([candidateId, departmentId])
  @@index([departmentId, status, updatedAt])
  @@index([candidateId])
  @@index([hrOwnerId])
  @@index([jobPostingId])
}

model CandidateResume {
  id         String   @id @default(cuid())
  candidateId String
  fileName   String
  mimeType   String
  sizeBytes  Int
  storageKey String
  storageUrl String
  uploadedAt DateTime @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, storageKey])
  @@index([candidateId, uploadedAt])
}

model CandidateAssessment {
  id          String   @id @default(cuid())
  candidateId String
  inviteId    String   @unique
  attemptId   String?  @unique
  createdAt   DateTime @default(now())
  createdById String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  invite      Invite    @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  attempt     Attempt?  @relation(fields: [attemptId], references: [id], onDelete: SetNull)
  attemptHistory CandidateAssessmentAttempt[]
  milestones  CandidateMilestone[]

  @@index([candidateId, createdAt])
}

model CandidateAssessmentAttempt {
  id                  String   @id @default(cuid())
  candidateAssessmentId String
  attemptId           String   @unique
  linkedAt            DateTime @default(now())
  candidateAssessment CandidateAssessment @relation(fields: [candidateAssessmentId], references: [id], onDelete: Cascade)
  attempt             Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([candidateAssessmentId, attemptId])
  @@index([candidateAssessmentId, linkedAt])
}

model CandidateNote {
  id          String   @id @default(cuid())
  candidateId String
  type        String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
}

model CandidateMilestone {
  id                   String                    @id @default(cuid())
  candidateId          String
  type                 String
  title                String
  status               CandidateMilestoneStatus
  sortOrder            Int
  mode                 String
  date                 DateTime?
  notes                String?
  score                Float?
  result               String?
  recommendation       String?
  candidateAssessmentId String?                  @unique
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  candidate            Candidate                 @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateAssessment  CandidateAssessment?      @relation(fields: [candidateAssessmentId], references: [id], onDelete: SetNull)
  checks               CandidateMilestoneCheck[]
  interviewPanel       InterviewPanel?

  @@unique([candidateId, sortOrder])
  @@index([candidateId, sortOrder])
}

model CandidateMilestoneCheck {
  id          String   @id @default(cuid())
  milestoneId String
  type        String
  status      String
  notes       String?
  actorId     String?
  actorName   String?
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  milestone   CandidateMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, type])
  @@index([milestoneId])
}

model CandidateActivityEvent {
  id         String   @id @default(cuid())
  candidateId String
  actorId    String?
  actorName  String?
  event      String
  entityType String?
  entityId   String?
  detail     String?
  createdAt  DateTime @default(now())
  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
}

model JobPosting {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  roleId      String?
  departmentId String?
  screenerPresetId String?
  summary     String
  description String
  salaryMin   Int?
  salaryMax   Int?
  teamSize    Int?
  techStack   String?
  remotePolicy String?
  isPublished Boolean  @default(false)
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  role        RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  screenerPreset AssessmentPreset? @relation(fields: [screenerPresetId], references: [id], onDelete: SetNull)
  applications CandidateApplication[]

  @@index([roleId])
  @@index([departmentId])
  @@index([screenerPresetId])
  @@index([isPublished, isOpen, updatedAt])
}

model CandidateApplication {
  id           String   @id @default(cuid())
  candidateId  String
  jobPostingId String
  status       String
  coverNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([candidateId, jobPostingId])
  @@index([candidateId, createdAt])
  @@index([jobPostingId, status, createdAt])
}

model Employee {
  id               String    @id @default(cuid())
  candidateId      String?   @unique
  employeeNumber   String    @unique
  fullName         String
  email            String    @unique
  phone            String?
  title            String?
  roleId           String?
  departmentId     String?
  managerId        String?
  employmentType   String    @default("full_time")
  employmentStatus String    @default("active")
  startDate        DateTime
  probationEndDate DateTime?
  endDate          DateTime?
  location         String?
  level            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  candidate        Candidate?  @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  role             RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager          Employee?   @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports          Employee[]  @relation("EmployeeManager")
  activityEvents   EmployeeActivityEvent[]
  goals            EmployeeGoal[]
  reviews          PerformanceReview[]

  @@index([departmentId, employmentStatus])
  @@index([managerId])
  @@index([roleId])
  @@index([employmentStatus, startDate])
}

model EmployeeActivityEvent {
  id         String   @id @default(cuid())
  employeeId String
  actorId    String?
  actorName  String?
  event      String
  detail     String?
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, createdAt])
}

model EmployeeGoal {
  id          String      @id @default(cuid())
  employeeId  String
  title       String
  description String?
  category    String      @default("performance")
  status      String      @default("active")
  targetDate  DateTime?
  progress    Int         @default(0)
  createdById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  checkIns    GoalCheckIn[]

  @@index([employeeId, status])
  @@index([employeeId, targetDate])
}

model GoalCheckIn {
  id               String      @id @default(cuid())
  goalId           String
  notes            String
  progressSnapshot Int
  createdById      String?
  createdAt        DateTime    @default(now())
  goal             EmployeeGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId, createdAt])
}

model PerformanceReview {
  id                      String    @id @default(cuid())
  employeeId              String
  reviewerId              String
  period                  String
  type                    String    @default("annual")
  status                  String    @default("draft")
  overallRating           Int?
  strengths               String?
  improvements            String?
  nextPeriodFocus         String?
  employeeAcknowledgedAt  DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  employee                Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, createdAt])
  @@index([reviewerId, status])
}

model CandidateOffer {
  id                 String                @id @default(cuid())
  candidateId        String                @unique
  status             CandidateOfferStatus  @default(draft)
  compensationType   String                @default("salary")
  compensationAmount Int?
  currency           String                @default("USD")
  targetStartDate    DateTime?
  expiresAt          DateTime?
  offerNotes         String?
  sentAt             DateTime?
  respondedAt        DateTime?
  createdById        String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  candidate          Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@index([candidateId])
}

model InterviewPanel {
  id          String   @id @default(cuid())
  candidateId String
  milestoneId String?  @unique
  roundNumber Int
  roundName   String
  format      String   @default("in_person")
  scheduledAt DateTime?
  durationMin Int      @default(60)
  status      String   @default("scheduled")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  candidate   Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  milestone   CandidateMilestone?  @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  members     InterviewPanelMember[]
  feedbacks   InterviewFeedback[]

  @@index([candidateId, roundNumber])
  @@index([status, scheduledAt])
}

model InterviewPanelMember {
  id        String         @id @default(cuid())
  panelId   String
  userId    String
  role      String         @default("interviewer")
  createdAt DateTime       @default(now())
  panel     InterviewPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([panelId, userId])
  @@index([panelId])
  @@index([userId])
}

model InterviewFeedback {
  id                String         @id @default(cuid())
  panelId           String
  interviewerId     String
  overallRating     Int?
  recommendation    String?
  competencyJson    Json?
  strengths         String?
  concerns          String?
  privateNotes      String?
  submittedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  panel             InterviewPanel @relation(fields: [panelId], references: [id], onDelete: Cascade)
  interviewer       User           @relation(fields: [interviewerId], references: [id], onDelete: Cascade)

  @@unique([panelId, interviewerId])
  @@index([panelId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actorEmail String?
  targetId   String
  targetType String
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([targetId, targetType])
  @@index([actorId])
  @@index([createdAt])
}
